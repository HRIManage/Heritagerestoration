# Google reviews integration
# Preferred: Google Business Profile API. Requires OAuth access to the verified business profile.
GOOGLE_BUSINESS_PROFILE_ACCOUNT_ID=
GOOGLE_BUSINESS_PROFILE_LOCATION_ID=
GOOGLE_BUSINESS_PROFILE_CLIENT_ID=
GOOGLE_BUSINESS_PROFILE_CLIENT_SECRET=
GOOGLE_BUSINESS_PROFILE_REFRESH_TOKEN=


# Optional temporary/testing token. Prefer refresh-token OAuth above for production.
GOOGLE_BUSINESS_PROFILE_ACCESS_TOKEN=

# Fallback option: Places Details API. This only returns a small review sample.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# Default: 6 hours
GOOGLE_REVIEWS_CACHE_MS=21600000
GOOGLE_REVIEWS_LIMIT=6
